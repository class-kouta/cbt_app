APP_NAME=cbt_app
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=cbt_db
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=cbt-app
AWS_ENDPOINT=https://0bd9d40aeb61963dfa9167ed89aeffc3.r2.cloudflarestorage.com
AWS_URL=https://pub-440dbe62d7b24b99b8c94d47b648e399.r2.dev
AWS_USE_PATH_STYLE_ENDPOINT=true

# ローカル開発でもR2から直接音声を配信するため通常は空でOK
# ローカルファイルを使いたい場合のみ http://localhost:8081 を設定
MINDFULNESS_AUDIO_BASE_URL=

VITE_APP_NAME="${APP_NAME}"

# HTTP Basic認証設定
USE_BASIC_AUTH=false
BASIC_AUTH_USERNAME=your-username
BASIC_AUTH_PASSWORD=your-password
